APP_ENV=production
APP_NAME=Sashecka API
APP_VERSION=0.1.0
API_PREFIX=/api/v1
APP_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
DATABASE_URL=postgresql+psycopg://sashecka:change-me@postgres:5432/sashecka
ENABLE_DOCS=false
ALLOWED_HOSTS=example.com
FORWARDED_ALLOW_IPS=*
HOST=0.0.0.0
PORT=8000
